# Plataforma de Doação e Troca – Docker Compose Environment Variables
# Copy this file to .env and adjust the values before running `docker compose up`

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS – allow the frontend origin in development
CORS_ORIGINS=http://localhost:3000

# PostgreSQL credentials (used by both the db service and the backend)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=doacao_troca

# Backend database connection – hostname must match the db service name
DATABASE_URL=postgresql://postgres:postgres@db:5432/doacao_troca

# JWT – set a strong random SECRET_KEY before deploying to production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Frontend – API base URL accessible from the browser
NEXT_PUBLIC_API_URL=http://localhost:8000
