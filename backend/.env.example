# Plataforma de Doação e Troca – Environment Variables
# Copy this file to .env and adjust the values

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS – comma-separated list of allowed origins
# Use '*' only for development; restrict to your frontend domain in production
# Example: CORS_ORIGINS=https://app.example.com,https://www.example.com
CORS_ORIGINS=*

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/recircula_db

# JWT – set a strong random SECRET_KEY before deploying to production!
# Generate one with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Email (SMTP) – leave SMTP_HOST empty to skip sending e-mails (e.g. in development)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@recircula.app
SMTP_TLS=true

# Frontend base URL used in verification e-mail links
FRONTEND_URL=http://localhost:3000
