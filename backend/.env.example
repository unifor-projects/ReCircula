# Plataforma de Doacao e Troca - Backend Environment Variables
# Copy this file to .env and adjust the values

APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000

# PostgreSQL credentials (used by db service and backend URL)
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recircula_db

# Backend database connection - using docker service hostname
DATABASE_URL=postgresql://postgres:postgres@db:5432/recircula_db

# JWT
SECRET_KEY=change-this-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=7

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=smtp-password
SMTP_FROM=noreply@recircula.app
SMTP_TLS=true

# Frontend base URL used in verification e-mail links
FRONTEND_URL=http://localhost:3000
